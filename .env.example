# Firebase web app configuration — see docs/SETUP.md.
# Copy this file to .env for local development. For deployment, add these as
# GitHub Actions repository secrets/variables (see docs/DEPLOYMENT.md).
# These values are safe to expose in the client; access is controlled by
# database security rules (database.rules.json).
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_DATABASE_URL=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_APP_ID=
